@echo off
:: CMD 창의 제목 설정
title [태리 프로토콜] 경매 시스템 대시보드 구동기

:: 현재 파일이 위치한 폴더로 경로 강제 이동 (핵심: 이 명령어가 경로 문제를 해결합니다)
cd /d "%~dp0"

echo ===================================================
echo   [시스템 가동] 태리 경매 인텔리전스 (v8.5)
echo   명령어: py -m streamlit run app_v2.py
echo ===================================================
echo.
echo [안내] 시스템이 경로를 자동으로 찾았습니다. 잠시만 기다려 주세요...

:: 파이썬 실행
py -m streamlit run app_v2.py

:: 실행 중 오류 발생 시 내용을 확인할 수 있게 설정
if %errorlevel% neq 0 (
    echo.
    echo 🚨 [경고] 시스템 가동 중 오류가 발생했습니다.
    echo 🚨 app_v2.py 파일이 같은 폴더에 있는지 확인해 주세요.
    pause
)